{
  "name": "open-token",
  "version": "0.1.0",
  "description": "Local-first token analytics dashboard for AI development workflows.",
  "type": "module",
  "bin": {
    "open-token": "./bin/open-token.mjs"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "public",
    "index.html",
    "vite.config.mjs",
    "README.md"
  ],
  "scripts": {
    "start": "node ./bin/open-token.mjs",
    "dev": "node ./bin/open-token.mjs --no-open",
    "collect": "node ./bin/open-token.mjs --collect-only",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {},
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.3.5",
    "typescript": "^5.7.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  }
}
