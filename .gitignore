# Dependencies
node_modules/

# Build output
dist/
build/
coverage/

# TypeScript / Vite caches
*.tsbuildinfo
.vite/

# Local dashboard data generated by the collector.
# Keep the directory placeholder, but never commit generated session metadata.
public/local-data/*
!public/local-data/.gitkeep

# Environment and machine-local config
.env
.env.*
!.env.example
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS and editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
